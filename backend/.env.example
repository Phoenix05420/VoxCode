# PostgreSQL connection string used for auth and snippet persistence
DATABASE_URL="postgresql://username:password@localhost:5432/voxcode"

# Legacy local JWT secret for non-Clerk fallback auth
JWT_SECRET="super-secret-voxcode-key"

# Clerk backend JWT verification
CLERK_PEM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_CLERK_PEM_PUBLIC_KEY\n-----END PUBLIC KEY-----"
CLERK_ISSUER="https://your-instance.clerk.accounts.dev"
CLERK_AUTHORIZED_PARTIES="http://localhost:5173"

# Ollama API URL
MODEL_API_URL="http://localhost:11434"

# Ollama model name (change to your preferred model)
MODEL_NAME="qwen2.5-coder:7b"
